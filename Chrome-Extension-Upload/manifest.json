{
  "manifest_version": 3,
  "name": "JameClaw Companion",
  "description": "Compact Chrome extension for the local JameClaw assistant.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "favicon-96x96.png",
    "32": "favicon-96x96.png",
    "48": "favicon-96x96.png",
    "128": "favicon.png"
  },
  "host_permissions": [
    "http://localhost:18800/*",
    "http://127.0.0.1:18800/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "favicon-96x96.png",
      "32": "favicon-96x96.png"
    },
    "default_title": "JameClaw Companion",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
